# ──────────────────────────────────────────────────────────────────
# Variables d'environnement — renaud-renov.fr
# À configurer sur le serveur Hetzner au déploiement (ne JAMAIS committer le vrai .env)
# ──────────────────────────────────────────────────────────────────

# Brevo (envoi des emails du formulaire de devis) — https://app.brevo.com
BREVO_API_KEY=xkeysib-...

# Destinataires des notifications de demande de devis (séparés par des virgules)
ADMIN_EMAILS=artisan.renaud.couverture@gmail.com,jmoog27@gmail.com

# Expéditeur (adresse vérifiée + domaine authentifié DKIM/DMARC dans Brevo)
FROM_EMAIL=contact@renaud-renov.fr
FROM_NAME=Renaud Renov - Couvreur 28

# Cloudflare Turnstile (anti-robot du formulaire) — https://dash.cloudflare.com
TURNSTILE_SITE_KEY=0x...
TURNSTILE_SECRET_KEY=0x...

# Règles anti-spam centralisées (optionnel — fallback intégré au code sinon)
# SPAM_RULES_URL=https://raw.githubusercontent.com/.../rules.json
# SPAM_RULES_TTL=3600
