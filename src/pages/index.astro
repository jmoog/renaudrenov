---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site.ts';
import services from '../data/services.json';
import villes from '../data/villes.json';
import AvisCarrousel from '../components/AvisCarrousel.astro';
import CtaDevis from '../components/CtaDevis.astro';
import reviews from '../data/reviews.json';
---
<BaseLayout
  title="Couvreur en Eure-et-Loir (28) — Renaud Renov | Devis gratuit"
  description="Nettoyage et démoussage de toiture, couverture, zinguerie et ravalement de façade en Eure-et-Loir. Artisan couvreur à Villiers-le-Morhier, garantie décennale, déplacement et devis gratuits."
>
  <!-- ── Hero clair, deux colonnes ────────────────────────────── -->
  <section class="hero">
    <div class="conteneur hero__grille">
      <div class="hero__texte">
        <p class="hero__badge"><span class="hero__point" aria-hidden="true"></span> Devis gratuit sous 48 h</p>
        <h1>Couvreur en Eure-et-Loir (28)</h1>
        <p class="hero__marque">RENAUD RENOV</p>
        <p class="hero__google">
          <span class="hero__etoiles" aria-hidden="true">★★★★★</span>
          <strong>{reviews.note.toLocaleString('fr-FR')}/5 sur Google · {reviews.nombre} avis</strong>
        </p>
        <p class="hero__accroche">
          Entreprise familiale de couverture installée à <strong>{SITE.ville}</strong>, je réalise
          tous vos travaux de toiture : <strong>nettoyage et démoussage</strong>, traitement hydrofuge,
          réparation, rénovation, zinguerie et ravalement de façade.
        </p>
        <p>
          Un savoir-faire transmis <strong>de père en fils</strong>, au service des particuliers de
          l'<strong>Eure-et-Loir</strong> (<strong>28</strong>), avec la garantie décennale sur
          l'ensemble de mes travaux. Devis gratuit et sans engagement.
        </p>
        <p>Mon métier, c'est de prendre soin de votre toit :</p>
        <ul>
          <li><strong>Nettoyage et démoussage</strong> de toiture, application de <strong>traitements hydrofuges</strong> et anti-mousses.</li>
          <li><strong>Réparation</strong> de toiture : tuiles cassées, ardoises déplacées, faîtage et infiltrations.</li>
          <li><strong>Rénovation</strong> et <strong>couverture neuve</strong> en tuile ou ardoise.</li>
          <li><strong>Zinguerie</strong>, ravalement de façade et bâtiments métalliques.</li>
        </ul>
        <div class="hero__actions">
          <a href={SITE.telHref} class="btn btn--rouge">
            <svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1z"/></svg>
            {SITE.tel}
          </a>
          <a href="/devis-gratuit/" class="btn btn--bleu">Devis gratuit →</a>
        </div>
      </div>

      <div class="hero__media">
        <img
          class="hero__photo"
          src="/images/photos/hero-toiture-renaud-renov.webp"
          alt="Toiture en tuiles rénovée par Renaud Renov en Eure-et-Loir"
          fetchpriority="high"
          width="1500"
          height="2000"
        />
        <div class="carte hero__garantie">
          <img src="/images/logo/logo-renaud-renov-128.webp" alt="" width="80" height="80" loading="lazy" />
          <p><strong>Garantie décennale</strong><br />Pour tous travaux de couverture</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Bandeau de réassurance ───────────────────────────────── -->
  <div class="reassurance">
    <ul>
      <li><svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm1 10.6 4.2 2.4-.8 1.3L11 13V7h2z"/></svg> Devis gratuit sous 48 h</li>
      <li><svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z"/></svg> Sans engagement</li>
      <li><svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2 4 5v6c0 5 3.4 9.7 8 11 4.6-1.3 8-6 8-11V5z"/></svg> Garantie décennale</li>
      <li><svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2 2 9h3v11h6v-6h2v6h6V9h3z"/></svg> Entreprise familiale (28)</li>
    </ul>
  </div>

  <!-- ── Avis clients ─────────────────────────────────────────── -->
  <AvisCarrousel />

  <!-- ── CTA devis ────────────────────────────────────────────── -->
  <CtaDevis />

  <!-- ── Services ─────────────────────────────────────────────── -->
  <section id="nos-services" class="section section--gris">
    <div class="conteneur">
      <p class="surtitre">Couvreur à {SITE.ville}</p>
      <h2>Notre savoir-faire d'artisan couvreur 28</h2>
      <div class="grille-services">
        {services.map((s) => (
          <a href="/devis-gratuit/" class="carte carte-service">
            <img src={s.image} alt={s.alt} loading="lazy" width="400" height="250" />
            <span class="carte-service__corps">
              <h3>{s.label}</h3>
              <p>{s.accroche}</p>
              <span class="carte-service__lien">{s.lien} →</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Spécialité : nettoyage & démoussage ──────────────────── -->
  <section class="section">
    <div class="conteneur">
      <div class="section__entete section__entete--gauche">
        <p class="surtitre">Notre spécialité</p>
        <h2>Nettoyage, démoussage et traitement hydrofuge de toiture</h2>
      </div>
    </div>
    <div class="conteneur duo">
      <div>
        <p>
          Avec le temps, mousses et lichens fragilisent votre couverture et retiennent l'humidité.
          Renaud Renov est <strong>spécialiste du nettoyage et du démoussage de toiture</strong> en
          Eure-et-Loir, pour préserver l'étanchéité et prolonger la durée de vie de votre toit.
        </p>
        <h3>Nettoyage et démoussage</h3>
        <p>
          Brossage, nettoyage adapté à votre couverture et élimination des mousses : nous redonnons
          à votre toiture son aspect et ses performances d'origine, tuiles comme ardoises.
        </p>
        <h3>Traitement hydrofuge et résine</h3>
        <p>
          Après le nettoyage, nous appliquons des traitements hydrofuges et des résines colorées
          professionnels qui protègent durablement les matériaux et limitent la repousse des mousses.
        </p>
        <a href="/devis-gratuit/" class="btn btn--bleu">Nettoyer et protéger mon toit</a>
      </div>
      <img
        src="/images/photos/nettoyage-demoussage-toiture.webp"
        alt="Nettoyage et démoussage d'une toiture en tuiles en Eure-et-Loir"
        loading="lazy"
        width="1200"
        height="900"
      />
    </div>
  </section>

  <!-- ── Couverture, rénovation & zinguerie ───────────────────── -->
  <section class="section section--bleute">
    <div class="conteneur">
      <div class="section__entete section__entete--gauche">
        <p class="surtitre">Tuile, ardoise, zinc</p>
        <h2>Couverture, rénovation et zinguerie en Eure-et-Loir</h2>
      </div>
    </div>
    <div class="conteneur duo duo--inverse">
      <div>
        <p>
          De la simple tuile cassée à la réfection complète d'une couverture, j'apporte le même
          soin et la même exigence. Je travaille la tuile terre cuite, l'ardoise naturelle et le
          zinc, en rénovation comme en neuf.
        </p>
        <h3>Rénovation et couverture neuve</h3>
        <p>
          Reprise partielle ou réfection complète : liteaunage, écran sous-toiture et couverture
          neuve pour un toit sain, étanche et durable pendant des décennies.
        </p>
        <h3>Zinguerie soignée</h3>
        <p>
          Noues, abergements, solins de cheminée et chéneaux : un travail du zinc précis qui assure
          une protection durable et une excellente étanchéité face aux intempéries.
        </p>
        <a href="/devis-gratuit/" class="btn btn--bleu">Demander un devis</a>
      </div>
      <img
        src="/images/photos/renovation-toiture.webp"
        alt="Rénovation de toiture avec liteaunage neuf sur charpente en Eure-et-Loir"
        loading="lazy"
        width="1200"
        height="900"
      />
    </div>
  </section>

  <!-- ── Pourquoi nous choisir ────────────────────────────────── -->
  <section class="section section--bleu pourquoi">
    <div class="conteneur">
      <h2>Pourquoi confier votre toiture à Renaud Renov ?</h2>
      <div class="etapes">
        <div class="etape">
          <span class="etape__numero">01</span>
          <h3>Un artisan d'ici, en Eure-et-Loir</h3>
          <p>
            Installés à Villiers-le-Morhier, nous connaissons les toitures de la région et
            intervenons rapidement dans toute l'Eure-et-Loir et ses alentours.
          </p>
        </div>
        <div class="etape">
          <span class="etape__numero">02</span>
          <h3>Une entreprise familiale</h3>
          <p>
            Le père et le fils sur le chantier : un savoir-faire transmis et l'amour du travail bien
            fait, salués par nos clients sur Google. Tous nos travaux sont couverts par la décennale.
          </p>
        </div>
        <div class="etape">
          <span class="etape__numero">03</span>
          <h3>Devis gratuit et sans engagement</h3>
          <p>
            Nous évaluons votre besoin sur place et vous remettons un devis clair et détaillé,
            gratuit et sans engagement, pour décider en toute sérénité.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Zone d'intervention ──────────────────────────────────── -->
  <section class="section section--gris">
    <div class="conteneur">
      <p class="surtitre">Zone d'intervention</p>
      <h2>Votre couvreur autour de {SITE.ville}</h2>
      <p>
        Basés à {SITE.ville} ({SITE.cp}), nous intervenons dans toute l'Eure-et-Loir et aux portes
        des Yvelines. Quelques communes où nous travaillons :
      </p>
      <ul class="nuage-villes">
        {villes.map((v) => (
          <li><span>{v.nom}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── CTA final ────────────────────────────────────────────── -->
  <section class="section section--bleu cta-final">
    <div class="conteneur">
      <h2>Demandez votre devis gratuit</h2>
      <p>
        Réponse rapide, déplacement et devis sans engagement partout en Eure-et-Loir.
        Appelez-nous ou écrivez-nous, nous prenons soin de votre toiture.
      </p>
      <div class="cta-final__actions">
        <a href={SITE.telHref} class="btn btn--rouge">
          <svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1z"/></svg>
          {SITE.tel}
        </a>
        <a href="/devis-gratuit/" class="btn btn--blanc">Formulaire de devis</a>
      </div>
    </div>
  </section>
</BaseLayout>
