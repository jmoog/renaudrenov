---
// En-tête double barre : 1) barre orange (téléphone + liens) 2) barre claire
// (logo + menu services). Repris du design Lafleur, adapté à Renaud Renov.
import { SITE } from '../data/site.ts';
import services from '../data/services.json';
const menuServices = services.slice(0, 6);
---
<header class="entete">
  <div class="entete__topbar">
    <div class="conteneur entete__topbar-int">
      <a href={SITE.telHref} class="entete__tel">
        <svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1z"/></svg>
        {SITE.tel}
      </a>
      <nav aria-label="Navigation secondaire">
        <ul class="entete__liens">
          <li><a href="/">Accueil</a></li>
          <li><a href="/a-propos/">À propos</a></li>
          <li><a href="/devis-gratuit/">Devis gratuit</a></li>
        </ul>
      </nav>
    </div>
  </div>

  <div class="entete__principal">
    <div class="conteneur entete__principal-int">
      <a href="/" class="entete__marque" aria-label={`${SITE.nom} — retour à l'accueil`}>
        <img src="/images/logo/logo-renaud-renov-256.webp" alt={`Logo ${SITE.nom} — ${SITE.slogan}`} width="72" height="72" />
        <span class="entete__marque-texte">
          <strong>RENAUD RENOV</strong>
          <small>Artisan couvreur · 28</small>
        </span>
      </a>

      <nav class="entete__nav" aria-label="Navigation principale">
        <button class="entete__burger" type="button" aria-expanded="false" aria-controls="menu-principal">
          <span class="visuallyhidden">Menu</span>
          <svg class="icone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
        </button>
        <ul id="menu-principal" class="entete__menu">
          <li><a href="/">Accueil</a></li>
          <li><a href="/a-propos/">À propos</a></li>
          {menuServices.map((s) => (
            <li><a href={`/#nos-services`}>{s.labelNav}</a></li>
          ))}
          <li class="entete__menu-cta"><a href={SITE.telHref} class="btn btn--rouge">{SITE.tel}</a></li>
          <li class="entete__menu-cta"><a href="/devis-gratuit/" class="btn btn--bleu">Devis gratuit</a></li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  .entete {
    position: sticky;
    top: 0;
    z-index: 50;
    box-shadow: var(--ombre);
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .entete--cachee { transform: translateY(-100%); }

  /* Barre 1 : orange */
  .entete__topbar { background: var(--rouge); }
  .entete__topbar-int {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 0.55rem;
  }
  .entete__tel {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    background: var(--blanc);
    color: var(--bleu);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    padding: 0.45em 1em;
    border-radius: var(--rayon);
    white-space: nowrap;
  }
  .entete__tel:hover { color: var(--rouge-fonce); }
  .entete__liens {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .entete__liens a {
    color: var(--blanc);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
  }
  .entete__liens a:hover { text-decoration: underline; color: var(--blanc); }

  /* Barre 2 : claire, logo + services */
  .entete__principal { background: var(--blanc); }
  .entete__principal-int {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 0.5rem;
  }
  .entete__marque { display: inline-flex; align-items: center; gap: 0.8rem; text-decoration: none; }
  .entete__marque img { height: 60px; width: auto; }
  .entete__marque-texte { display: flex; flex-direction: column; line-height: 1.1; }
  .entete__marque-texte strong { color: var(--bleu); font-size: 1.25rem; font-weight: 800; letter-spacing: 0.01em; }
  .entete__marque-texte small { color: var(--rouge); font-weight: 600; font-size: 0.78rem; }

  .entete__menu {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .entete__menu a:not(.btn) {
    text-decoration: none;
    color: var(--bleu);
    font-weight: 600;
    font-size: 0.95rem;
    transition: color var(--transition);
  }
  .entete__menu a:not(.btn):hover { color: var(--rouge); }
  .entete__menu-cta { display: none; }

  .entete__burger {
    display: none;
    background: none;
    border: none;
    color: var(--bleu);
    padding: 0.4rem;
    cursor: pointer;
  }
  .entete__burger .icone { width: 1.9rem; height: 1.9rem; }

  @media (max-width: 1180px) {
    .entete__liens { display: none; }
    .entete__topbar-int { justify-content: center; }
    .entete__menu a:not(.btn) { font-size: 0.9rem; }
    .entete__menu { gap: 1rem; }
  }
  @media (max-width: 980px) {
    .entete__topbar { display: none; }
    .entete__burger { display: block; }
    .entete__marque-texte small { display: none; }
    .entete__menu {
      display: none;
      position: absolute;
      inset-inline: 0;
      top: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--blanc);
      box-shadow: var(--ombre-forte);
      padding: 0.5rem 1rem 1.2rem;
    }
    .entete__menu.ouvert { display: flex; }
    .entete__menu li { border-bottom: 1px solid var(--gris-100); }
    .entete__menu a:not(.btn) { display: block; padding: 0.8em 0.2em; font-size: 1.02rem; }
    .entete__menu-cta { display: block; border-bottom: none !important; padding-top: 0.8rem; }
    .entete__menu-cta .btn { width: 100%; }
  }
</style>

<script>
  const burger = document.querySelector('.entete__burger');
  const menu = document.getElementById('menu-principal');
  burger?.addEventListener('click', () => {
    const ouvert = menu?.classList.toggle('ouvert');
    burger.setAttribute('aria-expanded', String(Boolean(ouvert)));
  });

  const entete = document.querySelector('.entete');
  const mobile = window.matchMedia('(max-width: 980px)');
  let tick = false;
  window.addEventListener('scroll', () => {
    if (tick) return;
    tick = true;
    requestAnimationFrame(() => {
      const cacher = mobile.matches && window.scrollY > 900 && !menu?.classList.contains('ouvert');
      entete?.classList.toggle('entete--cachee', Boolean(cacher));
      tick = false;
    });
  }, { passive: true });
</script>
