---
import { SITE } from '../data/site.ts';
import services from '../data/services.json';
import villes from '../data/villes.json';
import reviews from '../data/reviews.json';
---
<footer class="pied">
  <div class="conteneur pied__grille">
    <div class="pied__bloc pied__marque">
      <img src="/images/logo/logo-renaud-renov-256.webp" alt={`Logo ${SITE.nom}`} width="96" height="96" loading="lazy" />
      <p><strong>{SITE.nom}</strong><br />{SITE.slogan}</p>
      <p>{SITE.rue}<br />{SITE.cp} {SITE.ville}</p>
      <p>
        <a href={SITE.telHref}>{SITE.tel}</a><br />
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </p>
      <p class="pied__note">
        <span class="pied__etoiles" aria-hidden="true">★★★★★</span> {reviews.note.toLocaleString('fr-FR')}/5 · {reviews.nombre} avis Google
      </p>
    </div>

    <nav class="pied__bloc" aria-label="Nos services">
      <h2>Nos services</h2>
      <ul>
        {services.map((s) => (
          <li><a href="/#nos-services">{s.labelNav}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="pied__bloc" aria-label="Zone d'intervention">
      <h2>Eure-et-Loir et alentours</h2>
      <ul class="pied__villes">
        {villes.map((v) => (
          <li>{v.nom}</li>
        ))}
      </ul>
    </nav>

    <nav class="pied__bloc" aria-label="Informations">
      <h2>Informations</h2>
      <ul>
        <li><a href="/a-propos/">À propos</a></li>
        <li><a href="/devis-gratuit/">Devis gratuit et contact</a></li>
        <li><a href={SITE.facebook} rel="noopener" target="_blank">Facebook</a></li>
        <li><a href={SITE.googleAvis} rel="noopener" target="_blank">Avis Google</a></li>
        <li><a href="/mentions-legales/">Mentions légales</a></li>
      </ul>
    </nav>
  </div>

  <div class="pied__legal">
    <p><span>{SITE.nomLegal} — {SITE.slogan}.</span> <span>Garantie décennale.</span></p>
  </div>
</footer>

<style>
  .pied {
    background: var(--bleu-fonce);
    color: rgba(255, 255, 255, 0.85);
    margin-top: auto;
    font-size: 0.93rem;
  }
  .pied__grille {
    display: grid;
    gap: 2.5rem;
    padding-block: 3rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
  .pied__bloc h2 {
    color: var(--blanc);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }
  .pied__bloc ul { list-style: none; padding: 0; display: grid; gap: 0.4rem; }
  .pied__villes li { color: rgba(255, 255, 255, 0.7); }
  .pied a { color: rgba(255, 255, 255, 0.85); text-decoration: none; }
  .pied a:hover { color: var(--rouge); text-decoration: underline; }
  .pied__marque img { height: 80px; width: auto; margin-bottom: 1rem; border-radius: 50%; background: var(--blanc); }
  .pied__marque p { margin-block: 0.5rem; }
  .pied__etoiles { color: var(--etoile); letter-spacing: 0.1em; }
  .pied__note { font-weight: 600; color: var(--blanc); }
  .pied__legal {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    text-align: center;
    padding: 1.2rem 1rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
  }
  .pied__legal p { margin: 0; text-align: center; }
  .pied__legal span { display: inline-block; }

  @media (max-width: 800px) {
    .pied__grille { text-align: center; }
    .pied__grille p { text-align: center; }
    .pied__bloc h2 { text-align: center; }
    .pied__bloc ul { justify-items: center; }
    .pied__marque img { margin-inline: auto; }
  }
</style>
