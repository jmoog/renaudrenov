---
// Bandeau CTA devis : photo de l'artisan à gauche, panneau marine à droite.
import { SITE } from '../data/site.ts';
---
<section class="cta-devis">
  <div class="conteneur cta-devis__grille">
    <img
      class="cta-devis__photo"
      src="/images/photos/artisan-sur-toit.webp"
      alt="Artisan Renaud Renov au travail sur une toiture en tuiles en Eure-et-Loir"
      loading="lazy"
      width="1500"
      height="2000"
    />
    <div class="cta-devis__panneau">
      <h2>Contactez votre artisan couvreur</h2>
      <p class="cta-devis__texte">
        Une toiture à nettoyer, des tuiles à remplacer ou un projet de rénovation ?
        J'interviens à {SITE.ville} et dans toute l'{SITE.departement} ({SITE.departementNum}),
        rapidement et même en urgence. Déplacement, conseil et devis détaillé gratuits, sans engagement.
      </p>
      <ul>
        <li>Entreprise familiale, père &amp; fils.</li>
        <li>Travail soigné et durable.</li>
        <li>Garantie décennale.</li>
      </ul>
      <div class="cta-devis__actions">
        <a href={SITE.telHref} class="btn btn--rouge">
          <svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1z"/></svg>
          {SITE.tel}
        </a>
        <a href="/devis-gratuit/" class="btn btn--blanc">Devis gratuit →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-devis { padding-block: clamp(2.5rem, 5vw, 4rem); }
  .cta-devis__grille {
    display: grid;
    border-radius: var(--rayon);
    overflow: hidden;
    box-shadow: var(--ombre-forte);
  }
  .cta-devis__photo { width: 100%; height: 100%; object-fit: cover; }
  .cta-devis__panneau {
    background: var(--bleu);
    color: var(--blanc);
    padding: clamp(2rem, 5vw, 4rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    text-align: left;
    gap: 1.4rem;
  }
  .cta-devis__panneau h2 { color: var(--blanc); }
  .cta-devis__texte { max-width: 46ch; margin: 0; }
  .cta-devis__panneau ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.4rem;
    font-size: 1.1rem;
    text-align: left;
  }
  .cta-devis__panneau li::before {
    content: "•";
    color: var(--rouge);
    font-weight: 800;
    margin-right: 0.6em;
  }
  .cta-devis__actions { display: flex; flex-wrap: wrap; justify-content: flex-start; gap: 0.9rem; }
  @media (max-width: 800px) {
    .cta-devis__actions { justify-content: center; width: 100%; }
  }
  @media (min-width: 900px) {
    .cta-devis__grille { grid-template-columns: 1fr 1fr; }
  }
</style>
