---
// Barre de contact fixe en bas d'écran sur mobile : appel, WhatsApp, devis.
import { SITE } from '../data/site.ts';
---
<div class="contact-flottant" role="complementary" aria-label="Contact rapide">
  <a href={SITE.telHref} class="contact-flottant__btn contact-flottant__btn--appel">
    <svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .57 3.6 1 1 0 0 1-.25 1z"/></svg>
    Appeler
  </a>
  <a href={SITE.whatsapp} class="contact-flottant__btn contact-flottant__btn--whatsapp" rel="noopener" target="_blank">
    <svg class="icone" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.9-1.4A10 10 0 1 0 12 2zm5.3 14.1c-.2.6-1.2 1.2-1.7 1.2-.4.1-1 .1-1.6-.1a13 13 0 0 1-1.5-.5 11.5 11.5 0 0 1-4.4-3.9 5 5 0 0 1-1-2.7c0-1.3.7-1.9 1-2.2.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c0 .2.1.3 0 .5l-.3.5-.5.5c-.1.2-.3.3-.1.6.2.4.8 1.4 1.8 2.2 1.2 1.1 2.2 1.4 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2 1c.3.1.5.2.6.3 0 .1 0 .7-.2 1.2z"/></svg>
    WhatsApp
  </a>
  <a href="/devis-gratuit/" class="contact-flottant__btn contact-flottant__btn--devis">
    <svg class="icone" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M9 15l2 2 4-4"/></svg>
    Devis gratuit
  </a>
</div>

<style>
  .contact-flottant {
    position: fixed;
    inset-inline: 0;
    bottom: 0;
    z-index: 60;
    display: none;
    grid-template-columns: 1fr 1fr 1.3fr;
    box-shadow: 0 -4px 16px rgba(23, 52, 69, 0.18);
    transform: translateY(110%);
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .contact-flottant--visible { transform: translateY(0); }
  .contact-flottant__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45em;
    padding: 0.9em 0.5em;
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
    color: var(--blanc);
  }
  .contact-flottant__btn:hover { color: var(--blanc); }
  .contact-flottant__btn--appel { background: var(--bleu); }
  .contact-flottant__btn--whatsapp { background: #1faa54; }
  .contact-flottant__btn--devis { background: var(--rouge); }

  @media (max-width: 980px) {
    .contact-flottant { display: grid; }
    :global(body) { padding-bottom: calc(56px + env(safe-area-inset-bottom)); }
    .contact-flottant { padding-bottom: env(safe-area-inset-bottom); }
  }
</style>

<script>
  const barre = document.querySelector('.contact-flottant');
  let tickCF = false;
  window.addEventListener('scroll', () => {
    if (tickCF) return;
    tickCF = true;
    requestAnimationFrame(() => {
      barre?.classList.toggle('contact-flottant--visible', window.scrollY > 450);
      tickCF = false;
    });
  }, { passive: true });
</script>
